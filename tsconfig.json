{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "declaration": true,
    "sourceMap": true,

    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.js"
  ]
}